  version: 1

outputs:
- name: html_kicanvas
  comment: 'KiCanvas webpage'
  type: kicanvas
  category: 'KiCanvas'
  dir: 'KiCanvas'
  options:
    dnf_filter: _kibom_dnf_Config
    overlay: true
    source: ["schematic", "pcb", "project"]

